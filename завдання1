#include <iostream>
#include <stdlib.h>
using namespace std;

const int n = 5;

int main()
{
    double a[n][n];
    int i, j;

    cout << "Matrix:\n";

    for (i = 0; i < n; i++)
    {
        for (j = 0; j < n; j++)
        {
            a[i][j] = rand() % 50;
            cout << a[i][j] << '\t';
        }
        cout << '\n';
    }

    double max = a[0][0];
    int imax = 0, jmax = 0;

    for (i = 0; i < n; i++)
        for (j = 0; j < n; j++)
            if (a[i][j] > max)
            {
                max = a[i][j];
                imax = i;
                jmax = j;
            }

    cout << "\nMax element: " << max;
    cout << "\nPosition: [" << imax << "][" << jmax << "]\n";

    int center = n / 2;

    double temp = a[center][center];
    a[center][center] = a[imax][jmax];
    a[imax][jmax] = temp;

    cout << "\nMatrix after swap:\n";

    for (i = 0; i < n; i++)
    {
        for (j = 0; j < n; j++)
            cout << a[i][j] << '\t';
        cout << '\n';
    }

    return 0;
}
