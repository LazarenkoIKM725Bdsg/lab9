#include <iostream>
#include <stdlib.h>
using namespace std;

const int n = 5;

int main()
{
    int a[n][n];
    int i, j;

    cout << "Matrix:\n";

    for (i = 0; i < n; i++)
    {
        for (j = 0; j < n; j++)
        {
            a[i][j] = rand() % 21 - 10;
            cout << a[i][j] << '\t';
        }
        cout << '\n';
    }

    int sum = 0;

    for (i = 0; i < n; i++)
        for (j = 0; j < n; j++)
            sum += a[i][j];

    cout << "\nSum of all elements = " << sum << endl;

    int total = 0;

    for (j = 0; j < n; j++)
    {
        bool hasNegative = false;

        for (i = 0; i < n; i++)
            if (a[i][j] < 0)
                hasNegative = true;

        if (hasNegative)
        {
            for (i = 0; i < n; i++)
                total += a[i][j];
        }
    }

    cout << "Sum of selected columns = " << total << endl;

    return 0;
}
